#!/usr/bin/env python3
"""Print the Zed settings block for zed-codex-skills-acp."""

from __future__ import annotations

import json
import shutil
import sys
from pathlib import Path


def main() -> int:
    repo_root = Path(__file__).resolve().parents[1]
    proxy = repo_root / "bin/zed-codex-skills-acp"
    python = shutil.which("python3") or "/usr/bin/python3"

    snippet = {
        "agent_servers": {
            "Codex Skills": {
                "type": "custom",
                "command": python,
                "args": [str(proxy)],
                "env": {},
            }
        }
    }

    print("Add or merge this into your Zed settings.json:\n")
    print(json.dumps(snippet, indent=2))
    print("\nThen start a new Agent Panel thread with `Codex Skills`.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
